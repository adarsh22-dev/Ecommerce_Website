# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Razorpay
RAZORPAY_SECRET_KEY=your_razorpay_secret_key
NEXT_PUBLIC_RAZORPAY_PUBLISHABLE_KEY=your_razorpay_publishable_key
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# App
NEXT_PUBLIC_SITE_NAME=ECOM
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Resend Email
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=orders@ecom-store.com

# .NET Backend (when using)
EcommerceApi__ConnectionStrings__DefaultConnection=Host=localhost;Database=ecommerce;Username=postgres;Password=postgres
EcommerceApi__Jwt__Key=SuperSecretKeyForDevelopment123!
